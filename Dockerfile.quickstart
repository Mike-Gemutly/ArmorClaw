# ArmorClaw Quick Start Image
# Self-contained deployment image with bridge, wizard, and agent runtime
# Pull and run - setup wizard launches automatically

# ============================================================================
# Stage 1: Go Bridge Builder
# ============================================================================
FROM golang:1.24-bookworm AS bridge-builder

# Install CGO dependencies required by SQLCipher keystore
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc libc-dev libsqlite3-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Copy Go module files first for caching
COPY bridge/go.mod bridge/go.sum ./
RUN go mod download

# Copy bridge source
COPY bridge/ ./

# Build with CGO enabled (required for go-sqlcipher)
RUN CGO_ENABLED=1 GOOS=linux go build -ldflags="-s -w" -o armorclaw-bridge ./cmd/bridge

# ============================================================================
# Stage 2: Agent Runtime Builder
# ============================================================================
FROM debian:bookworm-slim AS agent-builder

ENV DEBIAN_FRONTEND=noninteractive

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl build-essential \
    python3 python3-pip python3-venv \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

# Create Python venv
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Install Python dependencies
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir aiohttp websockets python-dotenv

# ============================================================================
# Stage 3: Quick Start Runtime
# ============================================================================
FROM debian:bookworm-slim

ARG BUILD_DATE
ARG VCS_REF

LABEL org.opencontainers.image.title="ArmorClaw Quick Start" \
      org.opencontainers.image.description="Self-contained ArmorClaw deployment with setup wizard" \
      org.opencontainers.image.version="0.3.1" \
      org.opencontainers.image.created="${BUILD_DATE}" \
      org.opencontainers.image.revision="${VCS_REF}"

# Install runtime dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Core runtime
    python3 python3-venv \
    # Required for setup wizard and bridge
    curl wget jq socat \
    # Docker CLI client (container uses host's Docker socket)
    docker.io \
    # SQLite runtime library (bridge binary may dynamically link against it)
    libsqlite3-0 \
    # System utilities
    ca-certificates procps openssl gnupg \
    && rm -rf /var/lib/apt/lists/*

# Install Docker Compose V2 as both standalone binary and CLI plugin
# The CLI plugin path enables 'docker compose' (V2 subcommand form)
RUN curl -fsSL "https://github.com/docker/compose/releases/download/v2.24.0/docker-compose-$(uname -s)-$(uname -m)" -o /usr/local/bin/docker-compose && \
    chmod +x /usr/local/bin/docker-compose && \
    mkdir -p /usr/lib/docker/cli-plugins && \
    ln -sf /usr/local/bin/docker-compose /usr/lib/docker/cli-plugins/docker-compose

# Create ArmorClaw user
RUN groupadd -g 10001 armorclaw && \
    useradd -u 10001 -g armorclaw -m -s /bin/bash armorclaw

# Create directory structure
RUN mkdir -p /opt/armorclaw \
             /etc/armorclaw \
             /var/lib/armorclaw \
             /run/armorclaw \
             /var/log/armorclaw \
    && chown -R armorclaw:armorclaw /opt/armorclaw /etc/armorclaw /var/lib/armorclaw /run/armorclaw /var/log/armorclaw

# Copy bridge binary from builder
COPY --from=bridge-builder /build/armorclaw-bridge /opt/armorclaw/
RUN chmod +x /opt/armorclaw/armorclaw-bridge && \
    ln -sf /opt/armorclaw/armorclaw-bridge /usr/local/bin/armorclaw-bridge

# Copy agent runtime from builder
COPY --from=agent-builder /opt/venv /opt/venv
COPY --from=agent-builder /usr/lib/node_modules /usr/lib/node_modules
COPY --from=agent-builder /usr/bin/node /usr/bin/node
COPY --from=agent-builder /usr/bin/npm /usr/bin/npm
COPY --from=agent-builder /usr/bin/npx /usr/bin/npx

# Copy agent container files
COPY container/opt/openclaw/* /opt/armorclaw/agent/
COPY container/openclaw/ /opt/armorclaw/agent/openclaw/

# Copy setup scripts
COPY deploy/container-setup.sh /opt/armorclaw/
COPY deploy/health-check.sh /opt/armorclaw/
COPY deploy/create-matrix-admin.sh /opt/armorclaw/
COPY deploy/view-setup-log.sh /opt/armorclaw/
RUN chmod +x /opt/armorclaw/*.sh && \
    ln -sf /opt/armorclaw/view-setup-log.sh /usr/local/bin/view-setup-log

# Copy configuration templates
COPY configs/ /opt/armorclaw/configs/

# Copy docker-compose files
COPY docker-compose.yml /opt/armorclaw/
COPY docker-compose-full.yml /opt/armorclaw/
COPY docker-compose.matrix.yml /opt/armorclaw/
COPY docker-compose.bridge.yml /opt/armorclaw/

# Copy environment template
COPY .env.template /opt/armorclaw/.env.template

# Create quickstart entrypoint
RUN cat > /opt/armorclaw/quickstart.sh << 'ENTRYPOINT'
#!/bin/bash
# ArmorClaw Quick Start Entrypoint
# Launches container setup on first run, then starts bridge
# Version: 0.3.2

# NOTE: Do NOT use set -e. Transient failures must not kill the container.
# Critical commands check errors explicitly.

CONFIG_FILE="/etc/armorclaw/config.toml"
SETUP_FLAG="/etc/armorclaw/.setup_complete"
API_KEY_TEMP="/var/lib/armorclaw/.api_key_temp"
LOG_DIR="/var/log/armorclaw"
LOG_FILE="$LOG_DIR/setup.log"
VERSION="0.3.2"

# Debug mode (set ARMORCLAW_DEBUG=true to enable)
DEBUG="${ARMORCLAW_DEBUG:-false}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

#=============================================================================
# Logging Functions
#=============================================================================

init_logging() {
    mkdir -p "$LOG_DIR" 2>/dev/null || true
    touch "$LOG_FILE" 2>/dev/null || true
    chmod 644 "$LOG_FILE" 2>/dev/null || true
}

log_to_file() {
    local level="$1"
    shift
    local message="$*"
    local timestamp
    timestamp=$(date -Iseconds 2>/dev/null || date '+%Y-%m-%dT%H:%M:%S%z')
    echo "[$timestamp] [$level] $message" >> "$LOG_FILE" 2>/dev/null || true
}

log_info()  { log_to_file "INFO" "$@"; }
log_error() { log_to_file "ERROR" "$@"; }
log_debug() { [ "$DEBUG" = true ] && log_to_file "DEBUG" "$@"; }

# Initialize logging first
init_logging

# Redirect all output to log file AND stdout (Phase 1: Persistent Log File System)
exec > >(tee -a "$LOG_FILE") 2>&1

log_info "ArmorClaw Quick Start v${VERSION} starting"
log_info "Debug mode: $DEBUG"

# Enable debug tracing if requested (Phase 3: Debug Mode)
if [ "$DEBUG" = true ]; then
    set -x
    log_debug "Debug tracing enabled"
fi

#=============================================================================
# Crash Handler (Phase 2: Crash Handler & Error Capture)
#=============================================================================

# Track if setup succeeded (for crash handler)
SETUP_SUCCEEDED=false

# Crash handler - shows error summary and log location on failure
crash_handler() {
    local exit_code=$?

    # Only run on failure (non-zero exit)
    if [ "$SETUP_SUCCEEDED" != true ] && [ $exit_code -ne 0 ]; then
        log_error "Setup failed with exit code: $exit_code"

        echo ""
        echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${RED}SETUP FAILED (exit code: $exit_code)${NC}"
        echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""

        # Clean up partial state
        echo -e "${YELLOW}Cleaning up partial state...${NC}"
        rm -f "$SETUP_FLAG" 2>/dev/null || true
        rm -f "$API_KEY_TEMP" 2>/dev/null || true
        rm -f /tmp/armorclaw-wizard.json 2>/dev/null || true

        # Reset terminal state in case Huh? left it in raw mode
        stty sane 2>/dev/null || true
        tput reset 2>/dev/null || true

        # Show log file location
        if [ -f "$LOG_FILE" ]; then
            echo ""
            echo -e "${CYAN}Log file saved to: $LOG_FILE${NC}"
            echo ""
            echo "To view the log:"
            echo "  docker cp armorclaw:$LOG_FILE ./setup.log"
            echo ""
            echo "To view inside container:"
            echo "  docker exec armorclaw cat $LOG_FILE"
            echo ""
            echo -e "${YELLOW}Last 20 lines of log:${NC}"
            echo ""
            tail -20 "$LOG_FILE" 2>/dev/null || echo "(no log available)"
            echo ""
        fi

        echo -e "${CYAN}Common issues and fixes:${NC}"
        echo "  • Docker socket not accessible - run with --user root"
        echo "  • Terminal incompatibility - try environment variable mode:"
        echo "      -e ARMORCLAW_SERVER_NAME=your-ip"
        echo "      -e ARMORCLAW_API_KEY=sk-your-key"
        echo "  • Permission denied - check volume permissions"
        echo ""
    fi

    exit $exit_code
}
trap crash_handler INT TERM EXIT

# Disable cleanup trap on success (call this before normal exit)
disable_crash_handler() {
    SETUP_SUCCEEDED=true
    trap - INT TERM EXIT
}

# Handle --help and --version flags before any setup
if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
    echo "ArmorClaw Quick Start - Self-contained deployment image"
    echo ""
    echo "Usage: docker run [OPTIONS] armorclaw/quickstart [COMMAND]"
    echo ""
    echo "Commands:"
    echo "  --help, -h     Show this help message"
    echo "  --version, -v  Show version information"
    echo "  (no args)      Start ArmorClaw bridge (requires Docker socket)"
    echo ""
    echo "Deployment Profiles:"
    echo "  Quick Start (default)  - 2 prompts, running in ~2 minutes"
    echo "  Enterprise/Compliance  - PII/PHI scrubbing, HIPAA, audit logging"
    echo ""
    echo "  Set profile via: -e ARMORCLAW_PROFILE=enterprise"
    echo ""
    echo "Required volumes:"
    echo "  -v /var/run/docker.sock:/var/run/docker.sock"
    echo "  -v armorclaw-data:/etc/armorclaw (optional, persists config)"
    echo ""
    echo "Important: Run with --user root to access Docker socket:"
    echo "  docker run --user root -v /var/run/docker.sock:/var/run/docker.sock ..."
    echo ""
    echo "Environment variables (non-interactive mode):"
    echo "  ARMORCLAW_SERVER_NAME  Server domain or IP"
    echo "  ARMORCLAW_API_KEY      AI provider API key"
    echo "  ARMORCLAW_PROFILE      Deployment profile (quick|enterprise)"
    echo "  ARMORCLAW_HIPAA        Enable HIPAA mode (true|false)"
    echo "  ARMORCLAW_QUARANTINE   Enable quarantine mode (true|false)"
    echo "  ARMORCLAW_DEBUG        Enable debug mode (true|false)"
    echo ""
    echo "Examples:"
    echo "  # Quick start (interactive):"
    echo "  docker run -it --name armorclaw \\"
    echo "    -v /var/run/docker.sock:/var/run/docker.sock \\"
    echo "    -v armorclaw-data:/etc/armorclaw \\"
    echo "    -p 8443:8443 -p 6167:6167 -p 5000:5000 \\"
    echo "    mikegemut/armorclaw:latest"
    echo ""
    echo "  # Enterprise (non-interactive):"
    echo "  docker run -d --name armorclaw \\"
    echo "    -v /var/run/docker.sock:/var/run/docker.sock \\"
    echo "    -v armorclaw-data:/etc/armorclaw \\"
    echo "    -p 8443:8443 -p 6167:6167 -p 5000:5000 \\"
    echo "    -e ARMORCLAW_PROFILE=enterprise \\"
    echo "    -e ARMORCLAW_SERVER_NAME=your-domain.com \\"
    echo "    -e ARMORCLAW_API_KEY=sk-your-key \\"
    echo "    -e ARMORCLAW_HIPAA=true \\"
    echo "    mikegemut/armorclaw:latest"
    echo ""
    echo "  # Debug mode (verbose logging):"
    echo "  docker run -it --name armorclaw \\"
    echo "    -e ARMORCLAW_DEBUG=true \\"
    echo "    ..."
    SETUP_SUCCEEDED=true
    exit 0
fi

if [ "$1" = "--version" ] || [ "$1" = "-v" ]; then
    echo "ArmorClaw Quick Start v${VERSION}"
    echo "Bridge: $(/opt/armorclaw/armorclaw-bridge --version 2>/dev/null || echo 'installed')"
    echo "Node.js: $(node --version 2>/dev/null || echo 'installed')"
    SETUP_SUCCEEDED=true
    exit 0
fi

echo -e "${CYAN}"
echo "╔══════════════════════════════════════════════════════╗"
echo "║        ${BOLD}ArmorClaw Quick Start${NC}${CYAN}                          ║"
echo "║        ${BOLD}Self-Contained Deployment${NC}${CYAN}                    ║"
echo "╚══════════════════════════════════════════════════════╝"
echo -e "${NC}"

# Check if setup is needed
if [ ! -f "$SETUP_FLAG" ]; then
    echo -e "${CYAN}First run detected. Starting container setup...${NC}"
    echo ""

    # Check for Docker socket
    if [ ! -S /var/run/docker.sock ]; then
        echo -e "${RED}ERROR: Docker socket not found at /var/run/docker.sock${NC}"
        echo -e "${RED}This container requires Docker socket access.${NC}"
        echo ""
        echo "Run with: docker run -v /var/run/docker.sock:/var/run/docker.sock ..."
        exit 1
    fi

    # Run container setup via the Huh? TUI wizard.
    # The Go binary collects config interactively, then delegates
    # infrastructure setup (Docker Compose, Matrix, certs) to
    # container-setup.sh via --from-wizard. Secrets are passed
    # through environment variables, never written to disk.
    #
    # Fallback chain:
    #   1. Huh? TUI wizard (Go binary)
    #   2. Bash wizard (container-setup.sh)
    #   3. Environment variables (non-interactive)
    setup_failed=false

    if [ -x /opt/armorclaw/armorclaw-bridge ]; then
        echo -e "${CYAN}Launching Huh? TUI wizard...${NC}"
        log_info "Launching Huh? TUI wizard"

        # Run wizard and capture exit code
        set +e
        /opt/armorclaw/armorclaw-bridge container-setup
        WIZARD_EXIT=$?
        set -e

        # Reset terminal state after Huh? TUI (may leave terminal in raw mode)
        stty sane 2>/dev/null || true
        tput reset 2>/dev/null || true

        if [ $WIZARD_EXIT -ne 0 ]; then
            echo ""
            echo -e "${YELLOW}Huh? wizard exited with code $WIZARD_EXIT${NC}"
            log_error "Huh? wizard exited with code $WIZARD_EXIT"

            # Check if it's a user abort vs a crash
            if [ $WIZARD_EXIT -eq 130 ]; then
                echo -e "${YELLOW}Setup cancelled by user.${NC}"
                log_info "Setup cancelled by user"
                exit 130
            fi

            # Log error code INS-002 for wizard crash
            log_error "[INS-002] Huh? wizard crashed - attempting fallback"

            echo -e "${YELLOW}Attempting fallback to bash wizard...${NC}"
            cd /opt/armorclaw

            if [ -x ./container-setup.sh ]; then
                if ! ./container-setup.sh; then
                    echo -e "${YELLOW}Bash wizard also failed.${NC}"
                    log_error "Bash wizard also failed"
                    setup_failed=true
                fi
            else
                echo -e "${RED}Bash wizard not found.${NC}"
                log_error "Bash wizard not found"
                setup_failed=true
            fi
        else
            log_info "Huh? wizard completed successfully"
        fi
    else
        echo -e "${YELLOW}Huh? wizard not available, using bash wizard...${NC}"
        log_info "Huh? wizard not available, using bash wizard"
        cd /opt/armorclaw

        if [ -x ./container-setup.sh ]; then
            if ! ./container-setup.sh; then
                log_error "Bash wizard failed"
                setup_failed=true
            fi
        else
            echo -e "${RED}No setup wizard available.${NC}"
            log_error "No setup wizard available"
            setup_failed=true
        fi
    fi

    if [ "$setup_failed" = true ]; then
        echo ""
        echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${RED}ERROR: Container setup failed.${NC}"
        echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""

        # Check if we can fall back to environment variable mode
        if [ -n "${ARMORCLAW_SERVER_NAME:-}" ] && [ -n "${ARMORCLAW_API_KEY:-}" ]; then
            echo -e "${YELLOW}Attempting non-interactive setup with environment variables...${NC}"
            export NON_INTERACTIVE=true
            cd /opt/armorclaw

            if ./container-setup.sh; then
                echo -e "${GREEN}Non-interactive setup succeeded!${NC}"
                setup_failed=false
            else
                echo -e "${RED}Non-interactive setup also failed.${NC}"
            fi
        fi

        # If still failed, show help
        if [ "$setup_failed" = true ]; then
            echo "Common issues:"
            echo "  • Docker socket not accessible - run with --user root"
            echo "  • Terminal incompatibility - try a different terminal or SSH client"
            echo "  • Permission denied - fix volume permissions"
            echo ""
            echo "To retry with environment variables (non-interactive):"
            echo "  docker run -it --user root \\"
            echo "    -v /var/run/docker.sock:/var/run/docker.sock \\"
            echo "    -v armorclaw-config:/etc/armorclaw \\"
            echo "    -v armorclaw-data:/var/lib/armorclaw \\"
            echo "    -e ARMORCLAW_SERVER_NAME=your-ip \\"
            echo "    -e ARMORCLAW_API_KEY=sk-your-key \\"
            echo "    -e ARMORCLAW_PROFILE=quick \\"
            echo "    -p 8443:8443 -p 6167:6167 -p 5000:5000 \\"
            echo "    mikegemut/armorclaw:latest"
            echo ""
            echo "To retry:"
            echo "  1. Fix the issue above"
            echo "  2. Remove the container: docker rm -f armorclaw"
            echo "  3. Re-run the docker command"
            echo ""
            exit 1
        fi
    fi

    # Mark setup complete
    touch "$SETUP_FLAG"
fi

# Check configuration exists and has required fields
if [ ! -f "$CONFIG_FILE" ]; then
    echo -e "${RED}ERROR: Configuration not found at $CONFIG_FILE${NC}"
    echo -e "${RED}Run setup first: /opt/armorclaw/container-setup.sh${NC}"
    exit 1
fi

for field in socket_path homeserver_url db_path; do
    if ! grep -q "${field}" "$CONFIG_FILE" 2>/dev/null; then
        echo -e "${RED}ERROR: Config missing required field: $field${NC}"
        echo -e "${RED}Remove $SETUP_FLAG and re-run to repeat setup.${NC}"
        exit 1
    fi
done

echo -e "${GREEN}Starting ArmorClaw Bridge...${NC}"
echo ""

# Start bridge in background to inject API key
/opt/armorclaw/armorclaw-bridge &
BRIDGE_PID=$!

# Wait for bridge socket
echo -e "${CYAN}Waiting for bridge to initialize...${NC}"
max_attempts=30
attempt=0
while [ ! -S /run/armorclaw/bridge.sock ] && [ $attempt -lt $max_attempts ]; do
    sleep 1
    attempt=$((attempt + 1))
    echo -n "."
done
echo ""

if [ -S /run/armorclaw/bridge.sock ]; then
    echo -e "${GREEN}Bridge socket ready${NC}"

    # Brief wait for RPC server to finish initialization
    sleep 2

    # Inject API key if temp file exists (with retry)
    if [ -f "$API_KEY_TEMP" ]; then
        echo -e "${CYAN}Injecting API key into keystore...${NC}"
        source "$API_KEY_TEMP" 2>/dev/null || true

        if [ -n "$api_key" ]; then
            # Use provider from temp file, default to openai
            key_provider="${provider:-openai}"
            # Add API key via RPC with retry (bridge RPC may need a moment)
            inject_ok=false
            for inject_attempt in 1 2 3; do
                RESPONSE=$(echo "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"store_key\",\"params\":{\"id\":\"${key_provider}-default\",\"provider\":\"${key_provider}\",\"token\":\"$api_key\",\"display_name\":\"Default API\"}}" | \
                    socat - UNIX-CONNECT:/run/armorclaw/bridge.sock 2>/dev/null || echo '{"error":"failed"}')
                if echo "$RESPONSE" | grep -q '"result"'; then
                    inject_ok=true
                    break
                fi
                [ $inject_attempt -lt 3 ] && sleep 2
            done

            if [ "$inject_ok" = true ]; then
                echo -e "${GREEN}API key injected successfully${NC}"
                rm -f "$API_KEY_TEMP"
            else
                echo -e "${YELLOW}Warning: Could not inject API key after 3 attempts${NC}"
                echo -e "${YELLOW}Add manually via RPC: store_key${NC}"
            fi
        fi
    fi

    echo ""
    # ── Auto-claim OWNER role for setup admin user ──
    ADMIN_INFO_FILE="/var/lib/armorclaw/.admin_user"
    if [ -f "$ADMIN_INFO_FILE" ]; then
        ADMIN_USER=$(sed -n '1p' "$ADMIN_INFO_FILE")
        ADMIN_SERVER=$(sed -n '2p' "$ADMIN_INFO_FILE")
        ADMIN_MATRIX_ID="@${ADMIN_USER}:${ADMIN_SERVER}"

        echo -e "${CYAN}Assigning OWNER role to admin user...${NC}"

        # Step 1: Create provisioning token (with retry)
        SETUP_TOKEN=""
        for prov_attempt in 1 2 3; do
            TOKEN_RESP=$(echo '{"jsonrpc":"2.0","id":10,"method":"provisioning.start","params":{}}' | \
                socat - UNIX-CONNECT:/run/armorclaw/bridge.sock 2>/dev/null || echo '{}')
            SETUP_TOKEN=$(echo "$TOKEN_RESP" | jq -r '.result.setup_token // empty' 2>/dev/null)
            [ -n "$SETUP_TOKEN" ] && break
            [ $prov_attempt -lt 3 ] && sleep 2
        done

        if [ -n "$SETUP_TOKEN" ]; then
            # Step 2: Claim with admin's Matrix ID as device_id → first claim = OWNER
            CLAIM_RESP=$(printf '{"jsonrpc":"2.0","id":11,"method":"provisioning.claim","params":{"setup_token":"%s","device_id":"%s","device_name":"Admin (setup)","device_type":"element-x"}}' \
                "$SETUP_TOKEN" "$ADMIN_MATRIX_ID" | \
                socat - UNIX-CONNECT:/run/armorclaw/bridge.sock 2>/dev/null || echo '{}')

            CLAIM_ROLE=$(echo "$CLAIM_RESP" | jq -r '.result.role // empty' 2>/dev/null)
            if [ "$CLAIM_ROLE" = "OWNER" ]; then
                echo -e "${GREEN}✓ Admin ${ADMIN_MATRIX_ID} assigned OWNER role${NC}"
            else
                echo -e "${YELLOW}⚠ Admin role claim returned: ${CLAIM_ROLE:-unknown}${NC}"
            fi
        else
            echo -e "${YELLOW}⚠ Provisioning not available — admin can claim OWNER via ArmorChat QR${NC}"
        fi

        # Step 3: Generate a second token for ArmorChat QR code
        QR_RESP=$(echo '{"jsonrpc":"2.0","id":12,"method":"provisioning.start","params":{}}' | \
            socat - UNIX-CONNECT:/run/armorclaw/bridge.sock 2>/dev/null || echo '{}')

        QR_DATA=$(echo "$QR_RESP" | jq -r '.result.qr_data // empty' 2>/dev/null)
        QR_SETUP_TOKEN=$(echo "$QR_RESP" | jq -r '.result.setup_token // empty' 2>/dev/null)

        if [ -n "$QR_DATA" ]; then
            echo ""
            echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
            echo -e "${BOLD}ArmorChat Provisioning QR${NC}"
            echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
            echo ""
            echo "  Scan this link with ArmorChat to connect:"
            echo -e "  ${GREEN}${QR_DATA}${NC}"
            echo ""
            if command -v qrencode >/dev/null 2>&1; then
                echo "$QR_DATA" | qrencode -t UTF8 2>/dev/null || true
            else
                echo "  (Install qrencode for ASCII QR: apt-get install qrencode)"
            fi
            echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        fi

        # Clean up admin info file
        rm -f "$ADMIN_INFO_FILE"
    fi

    echo ""
    echo -e "${GREEN}ArmorClaw Bridge is running!${NC}"
    echo ""
    echo "To connect with Element X:"
    echo "  1. Open Element X"
    echo "  2. Set homeserver URL (shown during setup)"
    echo "  3. Log in with admin credentials"
    echo "  4. Open 'ArmorClaw Bridge' room and send !status"
    echo ""
    echo "To connect with ArmorChat:"
    echo "  Scan the QR code above, or run:"
    echo "    armorclaw-bridge generate-qr"
    echo ""

    # Wait for bridge process
    if kill -0 $BRIDGE_PID 2>/dev/null; then
        # Disable crash handler - setup succeeded, bridge is running
        log_info "Setup completed successfully - bridge running"
        disable_crash_handler
        wait $BRIDGE_PID
        EXIT_CODE=$?
        if [ $EXIT_CODE -ne 0 ]; then
            echo -e "${RED}Bridge exited with code $EXIT_CODE${NC}"
            log_error "Bridge exited with code $EXIT_CODE"
        fi
        exit $EXIT_CODE
    else
        echo -e "${RED}Bridge process is no longer running${NC}"
        log_error "Bridge process is no longer running"
        exit 1
    fi
else
    echo -e "${RED}ERROR: Bridge failed to create socket${NC}"
    log_error "Bridge failed to create socket"
    kill $BRIDGE_PID 2>/dev/null || true
    exit 1
fi
ENTRYPOINT

RUN chmod +x /opt/armorclaw/quickstart.sh

# Environment
ENV PATH="/opt/venv/bin:$PATH"
ENV PYTHONUNBUFFERED=1
ENV ARMORCLAW_CONFIG="/etc/armorclaw/config.toml"

# Expose ports (when running as bridge)
EXPOSE 8443 5000 6167

# Volumes
VOLUME ["/etc/armorclaw", "/var/lib/armorclaw", "/run/armorclaw", "/var/log/armorclaw"]

# Health check - verifies RPC server is responding, not just socket exists
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD echo '{"jsonrpc":"2.0","id":1,"method":"status"}' | socat - UNIX-CONNECT:/run/armorclaw/bridge.sock 2>/dev/null | grep -q '"result"' || exit 1

# Entrypoint - launches setup wizard on first run
ENTRYPOINT ["/opt/armorclaw/quickstart.sh"]
