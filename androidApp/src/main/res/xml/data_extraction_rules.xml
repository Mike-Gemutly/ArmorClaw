<?xml version="1.0" encoding="utf-8"?>
<!--
  Data extraction rules for Android 12+ backup.
  These rules define what data can be extracted from the app.
  Since ArmorClaw contains sensitive encrypted data, we disable all extraction.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="." />
        <exclude domain="sharedpref" path="encrypted_prefs.xml" />
        <exclude domain="file" path="." />
        <exclude domain="external" path="." />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="." />
        <exclude domain="sharedpref" path="encrypted_prefs.xml" />
        <exclude domain="file" path="." />
        <exclude domain="external" path="." />
    </device-transfer>
</data-extraction-rules>
