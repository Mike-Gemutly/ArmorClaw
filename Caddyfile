{$MATRIX_DOMAIN:matrix.localhost} {
    # Bridge API routes
    handle /api* {
        reverse_proxy armorclaw-sentinel:8080
    }
    handle /health {
        respond "OK" 200
    }
    handle /discover {
        reverse_proxy armorclaw-sentinel:8080
    }

    # Matrix routes (existing)
    handle /_matrix/* {
        reverse_proxy matrix:6167
    }

    handle /.well-known/matrix/client {
        header Content-Type application/json
        header Access-Control-Allow-Origin *
        respond `{"m.homeserver":{"base_url":"https://{$MATRIX_DOMAIN}"}}` 200
    }

    handle /.well-known/matrix/server {
        header Content-Type application/json
        header Access-Control-Allow-Origin *
        respond `{"m.server":"{$MATRIX_DOMAIN}:443"}` 200
    }

    handle {
        reverse_proxy matrix:6167
    }
}
