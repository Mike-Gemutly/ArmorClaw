# ===========================================
# ArmorClaw Environment Configuration Example
# ===========================================
#
# This file provides example configurations for both deployment modes.
# Copy this to .env and customize for your setup.
#
# IMPORTANT: Never commit actual .env file with secrets to version control!
# ===========================================

# ===========================================
# SENTINEL MODE (Public Deployment with TLS)
# ===========================================
# Use this mode for public-facing deployments with automatic HTTPS via Let's Encrypt.
# This is the recommended mode for production deployments.

# Server Mode Configuration
ARMORCLAW_SERVER_MODE=sentinel
# Valid values: native | sentinel
# - sentinel: Public deployment with TLS, domain-based routing
# - native: Local-only deployment using Unix sockets

# RPC Configuration
ARMORCLAW_RPC_TRANSPORT=tcp
# Valid values: tcp | unix
# - tcp: Used in sentinel mode for network access
# - unix: Used in native mode for secure local communication

ARMORCLAW_LISTEN_ADDR=0.0.0.0:8080
# Network address and port for RPC server (sentinel mode)
# - sentinel: 0.0.0.0:8080 (listens on all interfaces)
# - native: (empty string - uses Unix sockets)

ARMORCLAW_PUBLIC_BASE_URL=https://your-domain.example.com
# Public base URL for external access (sentinel mode only)
# - Must be a valid domain name with HTTPS
# - Required for Let's Encrypt certificate generation
# - Example: https://armorclaw.example.com

ARMORCLAW_ADMIN_TOKEN="GENERATE_TOKEN_HERE"
# Admin authentication token (sentinel mode only)
# - Generated automatically by installer
# - Required for admin API access
# - KEEP SECURE! Treat like a password
# - Generate with: openssl rand -base64 32 | tr -d '=+/'

ARMORCLAW_EMAIL="admin@example.com"
# Email address for Let's Encrypt SSL certificates (sentinel mode only)
# - Required for certificate generation and renewal
# - Used for expiry notifications
# - Example: admin@example.com

ARMORCLAW_PUBLIC_IP="192.168.1.100"
# Public IP address of your server (sentinel mode only)
# - Auto-detected by installer
# - Used for network configuration
# - Can be static IP or detected dynamically

# Secrets (REQUIRED - Generate Strong Values!)
ARMORCLAW_KEYSTORE_SECRET="CHANGE_ME_SECURE_SECRET"
# Encryption secret for the SQLCipher keystore
# - Used to encrypt sensitive data at rest
# - NEVER change after initial deployment
# - Generate with: openssl rand -base64 32 | tr -d '=+/'

ARMORCLAW_MATRIX_SECRET="CHANGE_ME_SECURE_SECRET"
# Secret for Matrix server registration
# - Used by bridge to authenticate with Matrix homeserver
# - Required for secure Matrix integration
# - Generate with: openssl rand -base64 32 | tr -d '=+/'

# Matrix Configuration
ARMORCLAW_MATRIX_ENABLED=true
# Enable Matrix integration
# - true: Use embedded Matrix/Conduit homeserver
# - false: Use external Matrix server

ARMORCLAW_MATRIX_HOMESERVER_URL=https://your-domain.example.com:6167
# Matrix homeserver URL
# - sentinel: https://your-domain.example.com:6167 (with TLS)
# - native: http://127.0.0.1:6167 (local only)
# - Format: http://host:port or https://host:port

# ===========================================
# NATIVE MODE (Local Deployment - Unix Sockets)
# ===========================================
# Use this mode for local development or secure local-only deployments.
# No TLS required, uses Unix sockets for secure communication.

# Server Mode Configuration
ARMORCLAW_SERVER_MODE=native
# Valid values: native | sentinel
# - native: Local-only deployment using Unix sockets
# - sentinel: Public deployment with TLS, domain-based routing

# RPC Configuration
ARMORCLAW_RPC_TRANSPORT=unix
# Valid values: tcp | unix
# - unix: Used in native mode for secure local communication
# - tcp: Used in sentinel mode for network access

ARMORCLAW_LISTEN_ADDR=
# Network address and port for RPC server (native mode)
# - native: (empty string - uses Unix sockets)
# - sentinel: 0.0.0.0:8080 (listens on all interfaces)

ARMORCLAW_PUBLIC_BASE_URL=
# Public base URL for external access (native mode: not used)
# - native: (empty string - not applicable)
# - sentinel: https://your-domain.example.com

ARMORCLAW_ADMIN_TOKEN=
# Admin authentication token (native mode: not used)
# - native: (empty string - not applicable)
# - sentinel: Required token for admin API access

ARMORCLAW_EMAIL=
# Email address for Let's Encrypt SSL certificates (native mode: not used)
# - native: (empty string - not applicable)
# - sentinel: Required for certificate generation

ARMORCLAW_PUBLIC_IP=
# Public IP address (native mode: not used)
# - native: (empty string - not applicable)
# - sentinel: Auto-detected IP address

# Secrets (REQUIRED - Generate Strong Values!)
ARMORCLAW_KEYSTORE_SECRET="CHANGE_ME_SECURE_SECRET"
# Encryption secret for the SQLCipher keystore
# - Used to encrypt sensitive data at rest
# - NEVER change after initial deployment
# - Generate with: openssl rand -base64 32 | tr -d '=+/'

ARMORCLAW_MATRIX_SECRET="CHANGE_ME_SECURE_SECRET"
# Secret for Matrix server registration
# - Used by bridge to authenticate with Matrix homeserver
# - Required for secure Matrix integration
# - Generate with: openssl rand -base64 32 | tr -d '=+/'

# Matrix Configuration
ARMORCLAW_MATRIX_ENABLED=true
# Enable Matrix integration
# - true: Use embedded Matrix/Conduit homeserver
# - false: Use external Matrix server

ARMORCLAW_MATRIX_HOMESERVER_URL=http://127.0.0.1:6167
# Matrix homeserver URL
# - native: http://127.0.0.1:6167 (local only)
# - sentinel: https://your-domain.example.com:6167 (with TLS)
# - Format: http://host:port or https://host:port

# ===========================================
# ADDITIONAL NOTES
# ===========================================
#
# Generating Secrets:
#   For each secret (KEYSTORE_SECRET, MATRIX_SECRET, ADMIN_TOKEN):
#     openssl rand -base64 32 | tr -d '=+/'
#
# Permission Requirements:
#   After creating .env, set restrictive permissions:
#     chmod 600 .env
#
# API Keys (NOT IN THIS FILE):
#   AI provider API keys are loaded from environment variables:
#   - OPENROUTER_API_KEY (recommended - access to many providers)
#   - OPEN_AI_KEY (OpenAI)
#   - ZAI_API_KEY (xAI/Grok)
#
#   Add these to your shell profile (.zshrc or .bashrc):
#     export OPENROUTER_API_KEY=sk-or-v1-xxx
#
# Security Best Practices:
#   1. Never commit .env to version control
#   2. Use strong, randomly generated secrets
#   3. Rotate secrets periodically
#   4. Use environment variables for API keys (not in .env)
#   5. Restrict .env file permissions (chmod 600)
#
# Installation:
#   The installer script (deploy/installer-v6.sh) generates this file
#   automatically with secure, randomly generated values.
#
#   Manual Setup:
#   1. Copy this example: cp configs/.env.example /etc/armorclaw/.env
#   2. Edit with your values: nano /etc/armorclaw/.env
#   3. Set permissions: chmod 600 /etc/armorclaw/.env
#   4. Restart services: docker compose restart
