# ArmorClaw Environment Configuration
# Copy to .env and customize: cp .env.example .env

# ===========================================
# Required: Authentication Secrets
# ===========================================
# Generate with: openssl rand -hex 32
ARMORCLAW_ADMIN_TOKEN=
ARMORCLAW_KEYSTORE_SECRET=
ARMORCLAW_MATRIX_SECRET=

# ===========================================
# Required: AI Provider
# ===========================================
AI_API_KEY=
AI_PROVIDER=openrouter

# ===========================================
# Matrix Configuration
# ===========================================
MATRIX_SERVER_NAME=matrix.armorclaw.com
MATRIX_ADMIN_USER=admin
MATRIX_ADMIN_PASSWORD=
MATRIX_BRIDGE_USER=bridge
MATRIX_BRIDGE_PASSWORD=

# ===========================================
# TURN/STUN Server
# ===========================================
TURN_SECRET=
# Auto-detected if empty
COTURN_EXTERNAL_IP=
TURN_SERVER_NAME=turn.matrix.armorclaw.com

# ===========================================
# Bridge Configuration
# ===========================================
ARMORCLAW_BRIDGE_HOST_PORT=8081
ARMORCLAW_BRIDGE_CONTAINER_PORT=8080
ARMORCLAW_RPC_TRANSPORT=tcp
ARMORCLAW_LISTEN_ADDR=0.0.0.0:8080
ARMORCLAW_SERVER_MODE=native
ARMORCLAW_PUBLIC_BASE_URL=
ARMORCLAW_HOST=0.0.0.0

# ===========================================
# Sentinel Mode (Caddy HTTPS)
# ===========================================
ARMORCLAW_EMAIL=
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
CADDY_CONFIG_PATH=/etc/armorclaw

# ===========================================
# HTTPS Server (Single Port Gateway)
# ===========================================
ARMORCLAW_HTTP_ENABLED=true
ARMORCLAW_HTTP_HOSTNAME=
ARMORCLAW_HTTP_PORT=8443
ARMORCLAW_HTTP_CERT_DIR=/var/lib/armorclaw/certs

# ===========================================
# Optional: Advanced
# ===========================================
ARMORCLAW_CONFIGS=./configs
ARMORCLAW_VERBOSE=false
ARMORCLAW_MATRIX_ROOM=
